# Sycamore LLM configuration (DeepSeek)
# Copy to .env and fill in your API key:
#   cp .env.example .env
#
# Then enable review in ~/.sycamore/config.toml:
#   [llm]
#   enabled = true

DEEPSEEK_API_KEY=

# Defaults used by config.toml [llm] section
SYCA_LLM_PROVIDER=deepseek
SYCA_LLM_MODEL=deepseek-v4-pro
SYCA_LLM_BASE_URL=https://api.deepseek.com
